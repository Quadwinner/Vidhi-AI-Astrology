# --- Ultravox / Voice Calls ---
# Optional: only needed if you enable Ultravox call flows locally.
REACT_APP_ULTRAVOX_AGENT_ID=61b21d16-2481-4681-838e-9afd6acbb1f3

# --- Stripe (Frontend Publishable Key) ---
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# --- CleverTap Configuration ---
REACT_APP_CLEVERTAP_ACCOUNT_ID=4W9-979-K67Z

# Valid Web SDK region codes: in1, us1, sg1, eu1, aps3
# Note: Setting "global" will be automatically converted to "eu1" by clevertapClient.ts
# because "global" is not a valid Web SDK region code. To avoid conversion, use a valid region code directly.
# Recommended: Use "eu1" for Europe/Global, "in1" for India, "us1" for US, etc.
REACT_APP_CLEVERTAP_REGION=eu1

# --- CleverTap Web Push Service Worker ---
# Set to true to enable service worker registration in development mode (localhost)
# Note: Push notifications require HTTPS and won't work on localhost even with SW enabled
# Use ngrok or mkcert for HTTPS testing in development
REACT_APP_SW_DEV=false

# --- Amplitude Configuration (optional) ---
REACT_APP_AMPLITUDE_API_KEY=your_amplitude_api_key_here

# Note: copy this file to .env, fill in real values, then restart `npm start`.
# Never commit populated .env files to version control.
